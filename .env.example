# ============================================================
# Adaptive RAG - Environment Variables
# ============================================================
# Copy this file and rename it to .env
# Then fill in your actual API keys and config values
# NEVER commit your .env file to GitHub!
# ============================================================


# ------------------------------------------------------------
# OpenAI (LLM Provider)
# Get your key at: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here


# ------------------------------------------------------------
# Tavily (Web Search)
# Get your key at: https://app.tavily.com
# ------------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here


# ------------------------------------------------------------
# Qdrant (Vector Database)
# Local default URL: http://localhost:6333
# Cloud: https://your-cluster.qdrant.io
# ------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_CODE_COLLECTION=code_documents
QDRANT_DOCS_COLLECTION=documents


# ------------------------------------------------------------
# MongoDB (Chat History Storage)
# Local default URL: mongodb://localhost:27017
# Cloud (MongoDB Atlas): mongodb+srv://...
# ------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=adaptive_rag
